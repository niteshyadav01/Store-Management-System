# ─────────────────────────────────────────────────────────────
#  Stockyard — Backend environment variables (EXAMPLE)
#  Copy to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────

MONGODB_URI=mongodb://127.0.0.1:27017/stockyard
PORT=5000
JWT_SECRET=replace_with_a_64_char_random_hex_string
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
