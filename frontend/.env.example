# ─────────────────────────────────────────────────────────────
#  Stockyard — Frontend environment variables (EXAMPLE)
#  Copy this file to .env and fill in real values.
#  .env is git-ignored — never commit it.
# ─────────────────────────────────────────────────────────────

# ── LOCAL DEVELOPMENT ─────────────────────────────────────────
# Leave empty → Vite proxy forwards /api calls to localhost:5000
VITE_API_URL=

# ── PRODUCTION (Render / Vercel / Netlify / VPS) ─────────────
# Set to your deployed backend URL (no trailing slash, no /api suffix)
# e.g.  VITE_API_URL=https://stockyard-api.onrender.com
# e.g.  VITE_API_URL=https://api.yourdomain.com
# VITE_API_URL=https://your-backend-url.com
